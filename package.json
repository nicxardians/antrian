{
  "name": "antrian-lan-desktop",
  "version": "1.0.0",
  "description": "Sistem Antrian LAN - Aplikasi Desktop",
  "main": "main.js",
  "author": "Antrian LAN",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-linux": "electron-builder --linux",
    "build-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.antrian.lan",
    "productName": "Antrian LAN",
    "publish": null,
    "files": [
      "**/*",
      "!.github/**",
      "!dist/**",
      "!*.bat",
      "!*.sh",
      "!*.bak",
      "!README.md"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico",
      "publish": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Antrian LAN"
    }
  },
  "dependencies": {
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
